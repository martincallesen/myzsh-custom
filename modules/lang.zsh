# Language and locale configuration
# Configure system locale, character encoding, and language settings
# View available locales with: locale or locale -a

# Primary language and locale setting (currently set to US English)
# Alternatives: da_DK.UTF-8 (Danish), etc.
# export LANG=da_DK.UTF-8
export LANG=en_US.UTF-8

# Override all locale settings to ensure consistent behavior across all categories
export LC_ALL=en_US.UTF-8

# Character encoding and type classification (UTF-8 for unicode support)
export LC_CTYPE=UTF-8
